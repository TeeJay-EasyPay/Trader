# Backend
AI_TRADER_API_TOKEN=replace-with-long-random-token
AI_TRADER_API_HOST=0.0.0.0
PORT=8765
AI_TRADER_DB_PATH=/data/audit.sqlite3
AI_TRADER_OUTPUT_DIR=/data
AI_TRADER_TRADING_LOG_PATH=/data/TRADING_LOG.md

# Broker and AI
ALPACA_API_KEY=replace-me
ALPACA_SECRET_KEY=replace-me
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini

# Guardrails
PAPER_TRADING_ONLY=true
ALLOW_SHORT_SELLING=false
MIN_CONFIDENCE_SCORE=0.85
MAX_RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS_PCT=0.03
MAX_OPEN_POSITIONS=3
