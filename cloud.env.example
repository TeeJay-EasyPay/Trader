# Backend
AI_TRADER_API_TOKEN=replace-with-long-random-token
AI_TRADER_API_HOST=0.0.0.0
PORT=8765
AI_TRADER_DB_PATH=/data/audit.sqlite3
AI_TRADER_OUTPUT_DIR=/data
AI_TRADER_TRADING_LOG_PATH=/data/TRADING_LOG.md
AI_TRADER_DATABASE_BACKEND=postgres
DATABASE_URL=replace-with-supabase-postgres-connection-string
SUPABASE_DATABASE_URL=
AI_TRADER_PROCESS_ROLE=render
AI_TRADER_DISABLE_API_BACKGROUND_WORKERS=true
AI_TRADER_REQUIRE_POSTGRES_IN_HOSTED=true

# Broker and AI
ALPACA_API_KEY=replace-me
ALPACA_SECRET_KEY=replace-me
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini

# Auto Trading - global flag is legacy compatibility; prefer broker-specific flags
AUTO_PAPER_TRADING=false
ALPACA_AUTO_TRADING=false
KRAKEN_AUTO_TRADING=false
COINBASE_AUTO_TRADING=false
BINANCE_AUTO_TRADING=false
IBKR_AUTO_TRADING=false
AUTO_TRADE_MIN_CONFIDENCE=0.85
AUTO_TRADE_MIN_PHILOSOPHY_FIT=0.85
MAX_AUTO_TRADE_AMOUNT=25
DEFAULT_STOP_LOSS_PCT=0.03
MAX_STOP_LOSS_PCT=0.05
CRYPTO_MAX_AUTO_TRADE_AMOUNT=10
CRYPTO_DEFAULT_STOP_LOSS_PCT=0.02
CRYPTO_MAX_STOP_LOSS_PCT=0.05
RESEARCH_SCHEDULER_ENABLED=false
AI_TRADER_WORKER_RESEARCH_ENABLED=true
AI_TRADER_PRODUCTION_SNAPSHOT_INTERVAL_SECONDS=300
AI_TRADER_WORKER_HEARTBEAT_INTERVAL_SECONDS=30
AI_TRADER_WORKER_JOB_TIMEOUT_SECONDS=180
AI_TRADER_BROKER_POLL_INTERVAL_SECONDS=600
RESEARCH_SCHEDULER_INTERVAL_MINUTES=60
RESEARCH_SCHEDULER_LIMIT=30
AUTO_EXECUTION_INTERVAL_SECONDS=60

# Crypto exchanges - keep trading disabled unless explicitly approved
KRAKEN_API_KEY=
KRAKEN_PRIVATE_KEY=
KRAKEN_API_SECRET=
KRAKEN_SANDBOX_MODE=true
KRAKEN_TRADING_ENABLED=false
KRAKEN_LIVE_TRADING_APPROVED=false
KRAKEN_SUBMIT_REAL_ORDERS=false
KRAKEN_TRADING_ALLOCATION_GBP=100
KRAKEN_MAX_ORDER_GBP=5
KRAKEN_MIN_ORDER_GBP=1
KRAKEN_MAX_OPEN_TRADES=1
KRAKEN_ALLOWED_PAIRS=XBTGBP,ETHGBP,SOLGBP
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_PASSPHRASE=
COINBASE_PORTFOLIO_ID=
COINBASE_TRADING_ENABLED=false
PAPER_TRADING_ONLY=true
ALLOW_SHORT_SELLING=false
MIN_CONFIDENCE_SCORE=0.85
MAX_RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS_PCT=0.03
MAX_OPEN_POSITIONS=3
