  },
  "build": {
    "preview": {
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_AI_TRADER_API_URL": "https://trader-no0f.onrender.com"
      }
    },
    "hosted-preview": {
      "channel": "hosted-preview",
      "android": {
        "buildType": "apk"
